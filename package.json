{
  "name": "turbo-template",
  "private": true,
  "license": "Elastic-2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,sql}\" --log-level=warn",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,json,sql}\" --log-level=warn",
    "postinstall": "husky",
    "integrationTest": "turbo run integrationTest",
    "lint": "turbo lint",
    "prepare": "husky",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,mdx}": "prettier --write",
    "*.sql": "prettier --write --plugin=prettier-plugin-sql --language=postgresql",
    "*.py": [
      "isort",
      "black"
    ]
  },
  "resolutions": {
    "postcss": "^8.5.14"
  },
  "devDependencies": {
    "@readtube/eslint-config": "*",
    "@readtube/typescript-config": "*",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^2.5.2",
    "prettier-plugin-sql": "^0.20.0",
    "turbo": "^2.9.12"
  },
  "packageManager": "yarn@4.9.1",
  "engines": {
    "node": ">=20"
  }
}
