DATABASE_URL=

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

TRANSCRIPT_API_KEY=

# JustOneAPI — third-party wrapper around Bilibili used for channel
# imports and refresh. Avoids direct Bilibili IP-reputation / WBI
# risk-control issues. Sign up at https://justoneapi.com to get a
# token. Used by BilibiliPlatform.fetchChannelSnapshot.
JUSTONEAPI_TOKEN=

# Vercel AI Gateway — used for LLM-powered article generation.
# Create a key at https://vercel.com/dashboard/ai/api-keys
# Not required when deployed on Vercel (OIDC is used automatically).
AI_GATEWAY_API_KEY=

CRON_SECRET=
