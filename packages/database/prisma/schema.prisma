// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

enum UserSourceType {
  CLERK
}

enum VideoPlatformType {
  YOUTUBE
  BILIBILI
}

enum ArticleStyle {
  NARRATIVE
  DIALOG
}

enum GenerationKind {
  SUMMARY
  ARTICLE
}

model User {
  id          String         @id @default(cuid())
  source_type UserSourceType @default(CLERK)
  // clerk user id
  source_id   String         @unique
  name        String
  email       String         @unique
  image       String?
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  // BCP-47 default target language for AI-generated summaries and
  // articles in the reader (e.g. "en", "zh"). null means "no preference"
  // — the reader defaults to "Original" and inbox-triggered generates
  // produce in the transcript's source language.
  preferred_language String?

  subscriptions      UserSubscription[]
  video_consumptions UserVideoConsumption[]
  folders            Folder[]
  stars              VideoStar[]
  saves              VideoSave[]
  archives           VideoArchive[]
  standalone_videos  StandaloneVideo[]
  playlists          Playlist[]
  notes              Note[]
}

model Channel {
  id          String            @id @default(cuid())
  source_type VideoPlatformType @default(YOUTUBE)
  // source platform channel id
  source_id   String
  name        String
  // Nullable because non-YouTube platforms (e.g. Bilibili) don't have a
  // native RSS feed — the refresh-channels cron is YouTube-only and
  // skips channels without rss_url. Existing YouTube rows keep their
  // feed URL; shadow channels for newly-added Bilibili videos are
  // created with rss_url = null.
  rss_url     String?
  // Extended metadata populated from TranscriptAPI /youtube/channel/latest.
  // All nullable because they're backfilled incrementally — older channels
  // may not have them until the next cron refresh picks them up.
  handle      String?
  description String?
  // TODO: remove this column, which is not used at all.
  verified    Boolean           @default(false)
  // URL to the channel's avatar/logo image. Sourced from the `thumbnails`
  // array in the TranscriptAPI response. Typically a 48px or 88px square
  // hosted on yt3.ggpht.com.
  logo_url    String?
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt
  checked_at  DateTime?

  videos        Video[]
  subscriptions UserSubscription[]

  @@unique([source_type, source_id], name: "channel_unique_source")
  @@unique([source_type, handle], name: "channel_unique_handle")
}

model UserSubscription {
  id         String    @id @default(cuid())
  user_id    String
  channel_id String
  // Per-subscription "read watermark". Videos in this channel whose
  // published_at is <= read_at are considered read by this user, even if
  // there is no explicit UserVideoConsumption row. Used for cheap bulk
  // mark-as-read (one UPDATE replaces N inserts) and for the configurable
  // initial subscription state (mark recent N videos as new, etc.).
  // null means no watermark — read state comes purely from consumptions.
  read_at    DateTime?
  // null = "Inbox root" (no folder). When a folder is deleted, subscriptions
  // fall back to root via SetNull.
  folder_id  String?
  // -1 = low, 0 = normal, 1 = priority
  priority   Int       @default(0)
  // When set, videos from this channel are hidden until this time passes.
  mute_until DateTime?
  created_at DateTime  @default(now())

  user    User    @relation(fields: [user_id], references: [source_id], onDelete: Cascade)
  channel Channel @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  folder  Folder? @relation(fields: [folder_id], references: [id], onDelete: SetNull)

  @@unique([user_id, channel_id], name: "subscription_unique_user_channel")
  @@index([channel_id], name: "subscription_index_on_channel_id")
  @@index([user_id, folder_id], name: "subscription_index_on_user_folder")
}

model Video {
  id                     String                   @id @default(cuid())
  channel_id             String
  source_type            VideoPlatformType        @default(YOUTUBE)
  // source platform video id
  source_id              String
  title                  String
  description            String?
  // Nullable because YouTube watch-page scrapes sometimes omit the
  // date microdata (consent-wall variants, serverless-IP responses).
  // We prefer a null over a synthetic `new Date()` placeholder so
  // callers can distinguish "unknown" from "actually published now,"
  // and a later scrape can backfill without colliding with a fake
  // stored date. For watermark / unread-count comparisons, callers
  // use the video's effective publish date — COALESCE(published_at,
  // created_at) — so a null-date video is still classified relative
  // to when we learned about it. See `videoNewerThanWatermark` and
  // `effectivePublishDate` in `lib/subscriptions.ts`.
  published_at           DateTime?
  created_at             DateTime                 @default(now())
  // Length of the video in seconds. Nullable because the channel scraper
  // may not always capture the duration string (Shorts, ad slots, etc.)
  // and we backfill incrementally as the cron refresh runs.
  duration_seconds       Int?
  // URL to the video's thumbnail image. Sourced from the TranscriptAPI
  // /youtube/channel/latest RSS response. Typically a 480×360 or
  // maxresdefault hosted on i.ytimg.com.
  thumbnail_url          String?
  // Sticky flag set the first time we attempt to fetch a transcript and
  // come back empty. Once true, the transcript route refuses to retry —
  // some videos genuinely have no captions and re-hammering the upstream
  // API on every reader open is wasteful for the user and the provider.
  // Reset by hand if a captionless video later gains captions.
  transcript_unavailable Boolean                  @default(false)
  // Full-text search vector over title + description. Backed by a STORED
  // GENERATED column — the migration SQL creates it with to_tsvector +
  // setweight. Prisma sees it as Unsupported, which is fine for writes
  // (generated) and for raw-SQL reads.
  search_tsv             Unsupported("tsvector")?

  channel        Channel                @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  transcripts    Transcript[]
  consumptions   UserVideoConsumption[]
  stars          VideoStar[]
  saves          VideoSave[]
  archives       VideoArchive[]
  standalone     StandaloneVideo[]
  playlist_items PlaylistVideo[]
  notes          Note[]
  embedding      VideoEmbedding?

  @@unique([channel_id, source_id], name: "video_unique_channel_source")
  @@unique([source_type, source_id], name: "video_unique_source")
  @@index([channel_id, published_at], name: "video_index_on_channel_published_at")
}

model UserVideoConsumption {
  id       String   @id @default(cuid())
  user_id  String
  video_id String
  read_at  DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [source_id], onDelete: Cascade)
  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@unique([user_id, video_id], name: "user_video_consumption_unique_user_video")
  @@index([video_id], name: "user_video_consumption_index_on_video_id")
}

model Transcript {
  id         String   @id @default(cuid())
  video_id   String
  language   String?
  text       String
  fetched_at DateTime
  created_at DateTime @default(now())
  video      Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)

  articles         Article[]
  summaries        Summary[]
  generation_runs  GenerationRun[]

  @@index([video_id], name: "transcript_index_on_video_id")
}

model Article {
  id             String       @id @default(cuid())
  transcript_id  String
  style          ArticleStyle
  // BCP-47 target language for this article (e.g. "en", "zh", "ja").
  // null means "Original" — the article was generated to match the
  // transcript's source language without an explicit target.
  language       String?
  // Record-keeping only: tracks which prompt version generated the row.
  // NOT part of the unique index — once an article exists for a
  // (transcript_id, style, language) triple, subsequent prompt-version
  // bumps leave it alone. Regeneration is an explicit, manual action.
  prompt_version String
  // model identifier, e.g. "anthropic/claude-sonnet-4.5"
  model          String
  content        String
  // token usage from the AI SDK result.usage promise
  usage          Json?
  generated_at   DateTime     @default(now())

  transcript Transcript @relation(fields: [transcript_id], references: [id], onDelete: Cascade)

  // Uniqueness on (transcript_id, style, language) is enforced by two
  // partial unique indexes added by raw SQL in the migration: one for
  // language IS NULL (one Original per style), one for language IS NOT
  // NULL (one row per (transcript_id, style, language) triple). Prisma
  // can't model partial indexes today, so we drop the @@unique attribute
  // here and use findFirst + try/catch on writes.
  @@index([transcript_id, style, language], name: "Article_transcript_id_style_language_idx")
}

model Summary {
  id             String   @id @default(cuid())
  transcript_id  String
  // BCP-47 target language for this summary (e.g. "en", "zh", "ja").
  // null means "Original" — the summary was generated to match the
  // transcript's source language without an explicit target.
  language       String?
  // one sentence, title-like, includes key info if present
  headline       String?
  // one paragraph, skimmable in 10-20 seconds
  short          String?
  // several paragraphs — a condensed re-write preserving logic flow and arguments
  full           String?
  prompt_version String
  model          String
  // { headline: {inputTokens, outputTokens}, short: {...}, full: {...} }
  usage          Json?
  generated_at   DateTime @default(now())

  transcript Transcript @relation(fields: [transcript_id], references: [id], onDelete: Cascade)

  // Uniqueness on (transcript_id, language) is enforced by two partial
  // unique indexes added by raw SQL in the migration: one for language
  // IS NULL (one Original per transcript), one for language IS NOT NULL
  // (one row per (transcript_id, language) pair). Prisma can't model
  // partial indexes today, so we use findFirst + try/catch on writes.
  @@index([transcript_id, language], name: "Summary_transcript_id_language_idx")
}

// Tracks an in-flight Vercel Workflow run for a summary or article so a
// second client (or the same client after a refresh) can tap into the
// existing stream instead of starting a duplicate generation. The row
// is created when the route first calls workflow `start()` and deleted
// by the workflow's persist step on success — see
// `apps/web/src/lib/workflows/runRegistry.ts` for the full lifecycle.
//
// `style` is set only for ARTICLE rows and stays null for SUMMARY (the
// summary route generates all three fields together, so its slot is
// keyed only by language). Uniqueness is enforced by partial unique
// indexes in the migration — Prisma can't model "(NULL, NULL) is a
// conflict" via @@unique today.
model GenerationRun {
  id            String         @id @default(cuid())
  transcript_id String
  kind          GenerationKind
  // null = Original (matches Summary/Article semantics).
  language      String?
  // null for SUMMARY rows; set to the requested ArticleStyle for ARTICLE rows.
  style         ArticleStyle?
  // Vercel Workflow runId returned by `start()`. Subsequent readers
  // call `getRun(run_id).getReadable({ startIndex: 0 })` to replay the
  // stream from the beginning.
  run_id        String
  started_at    DateTime       @default(now())

  transcript Transcript @relation(fields: [transcript_id], references: [id], onDelete: Cascade)

  @@index([transcript_id, kind, language, style], name: "GenerationRun_lookup_idx")
}

// ───────────────────────────────────────────────────────────────────────────
// Inbox feature expansion — organization, triage, notes, AI
// ───────────────────────────────────────────────────────────────────────────

// User-defined channel groupings in the sidebar. Sort order is manual.
model Folder {
  id         String   @id @default(cuid())
  user_id    String
  name       String
  sort_order Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user          User               @relation(fields: [user_id], references: [source_id], onDelete: Cascade)
  subscriptions UserSubscription[]

  // The composite unique on (user_id, name) doubles as a per-user index —
  // Postgres uses its leading column for any user-scoped range scan, so
  // a separate @@index([user_id]) would be redundant.
  @@unique([user_id, name], name: "folder_unique_user_name")
}

// Starred videos (favorites).
model VideoStar {
  id         String   @id @default(cuid())
  user_id    String
  video_id   String
  created_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [source_id], onDelete: Cascade)
  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@unique([user_id, video_id], name: "video_star_unique_user_video")
  @@index([video_id], name: "video_star_index_on_video_id")
}

// "Read later" queue — saved but not yet consumed.
model VideoSave {
  id         String   @id @default(cuid())
  user_id    String
  video_id   String
  created_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [source_id], onDelete: Cascade)
  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@unique([user_id, video_id], name: "video_save_unique_user_video")
  @@index([video_id], name: "video_save_index_on_video_id")
}

// Hidden from inbox until snooze_until passes. Index on snooze_until so a
// cheap cron can "wake" snoozed videos back into the inbox.
// Archived videos — removed from inbox but kept in history.
model VideoArchive {
  id          String   @id @default(cuid())
  user_id     String
  video_id    String
  archived_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [source_id], onDelete: Cascade)
  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@unique([user_id, video_id], name: "video_archive_unique_user_video")
  @@index([video_id], name: "video_archive_index_on_video_id")
}

// Tracks videos the user individually added to their personal library
// (via the "+ Add video" flow). The Video row still lives under a
// Channel — we auto-upsert a "shadow" Channel when the video's actual
// channel isn't in the user's subscriptions.
model StandaloneVideo {
  id         String   @id @default(cuid())
  user_id    String
  video_id   String
  created_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [source_id], onDelete: Cascade)
  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@unique([user_id, video_id], name: "standalone_video_unique_user_video")
  @@index([video_id], name: "standalone_video_index_on_video_id")
}

// User-owned playlists: a named grouping of videos that may span multiple
// channels. Sort order is manual, mirrors Folder.
model Playlist {
  id          String            @id @default(cuid())
  user_id     String
  source_type VideoPlatformType @default(YOUTUBE)
  // Platform playlist ID (e.g. PLxxxxxxx for YouTube). Used to link
  // back to the original playlist on the platform.
  source_id   String
  // Original playlist title from the source (e.g. YouTube). Kept
  // as-is so the user can always see the original even after renaming.
  name        String
  // Optional user-supplied override. When set, the UI shows this
  // as the primary label with `name` rendered in parentheses.
  custom_name String?
  sort_order  Int               @default(0)
  // Per-playlist read watermark, mirroring UserSubscription.read_at.
  // Videos in this playlist whose published_at <= read_at are
  // considered read. null means no watermark — read state comes
  // purely from UserVideoConsumption rows.
  read_at     DateTime?
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt

  user  User            @relation(fields: [user_id], references: [source_id], onDelete: Cascade)
  items PlaylistVideo[]

  @@unique([user_id, name], name: "playlist_unique_user_name")
  @@unique([user_id, source_type, source_id], name: "playlist_unique_user_source")
}

// Junction: many-to-many between Playlist and Video. A video may live in
// multiple playlists.
model PlaylistVideo {
  id          String   @id @default(cuid())
  playlist_id String
  video_id    String
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())

  playlist Playlist @relation(fields: [playlist_id], references: [id], onDelete: Cascade)
  video    Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@unique([playlist_id, video_id], name: "playlist_video_unique_playlist_video")
  @@index([video_id], name: "playlist_video_index_on_video_id")
}

// Per-video notes. timestamp_ms is optional: null = general note, set = pinned
// to a transcript timestamp.
model Note {
  id           String   @id @default(cuid())
  user_id      String
  video_id     String
  body         String
  timestamp_ms Int?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user  User  @relation(fields: [user_id], references: [source_id], onDelete: Cascade)
  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@index([user_id, video_id], name: "note_index_on_user_video")
}

// pgvector embedding per video. 1536 dims matches OpenAI's
// text-embedding-3-small (the model configured in apps/web/src/lib/ai/embed.ts).
// We use OpenAI for embeddings even though generation uses Google Gemini —
// they're routed independently through the Vercel AI Gateway. If you swap
// to a model with a different output size, bump EMBEDDING_PROMPT_VERSION
// and add a follow-up migration that ALTERs the column + rebuilds the
// HNSW index.
model VideoEmbedding {
  id             String                      @id @default(cuid())
  video_id       String                      @unique
  embedding      Unsupported("vector(1536)")
  // e.g. "openai/text-embedding-3-small"
  model          String
  // bump when the embedding input recipe (title + summary etc.) changes
  prompt_version String
  generated_at   DateTime                    @default(now())

  video Video @relation(fields: [video_id], references: [id], onDelete: Cascade)
}
