// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

model ClerkUser {
  id         String    @id @default(cuid())
  user_id    String    @unique
  name       String
  email      String    @unique
  image      String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  channels   Channel[]

  @@index([user_id], name: "clerk_user_index_on_user_id")
}

model Channel {
  id         String    @id @default(cuid())
  user_id    String
  // source platform channel id
  source_id  String
  name       String
  rss_url    String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  user       ClerkUser @relation(fields: [user_id], references: [user_id])
  videos     Video[]

  @@unique([user_id, source_id], name: "channel_unique_user_source")
  @@index([source_id], name: "channel_index_on_source_id")
}

model Video {
  id           String       @id @default(cuid())
  channel_id   String
  // source platform video id
  source_id    String
  title        String
  description  String?
  published_at DateTime
  read_at      DateTime?
  created_at   DateTime     @default(now())
  channel      Channel      @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  transcripts  Transcript[]

  @@unique([channel_id, source_id], name: "video_unique_channel_source")
  @@index([channel_id, published_at], name: "video_index_on_channel_published_at")
  @@index([source_id], name: "video_index_on_source_id")
}

model Transcript {
  id         String   @id @default(cuid())
  video_id   String
  language   String?
  text       String
  fetched_at DateTime
  created_at DateTime @default(now())
  video      Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@index([video_id], name: "transcript_index_on_video_id")
}
